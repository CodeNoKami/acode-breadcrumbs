{
  "name": "lumen.breadcrumbs",
  "version": "2.3.4",
  "description": "A smart, theme-adaptive VS Code-style Breadcrumbs bar for JavaScript, JSX, TypeScript, and TSX files. Real-time visual code structural scopes (Classes, Methods, Functions, Callbacks) with inline colorful icons!",
  "main": "dist/main.js",
  "repository": "https://github.com/CodeNoKami/acode-breadcrumbs",
  "author": "Lumen",
  "license": "MIT",
  "dependencies": {
    "@codemirror/language": "^6.12.3",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.1",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/javascript": "^1.5.4",
    "@lezer/lr": "^1.4.10",
    "acode-plugin-types": "^1.11.7-patch.2",
    "html-tag-js": "^1.8.2"
  },
  "devDependencies": {
    "esbuild": "^0.27.2",
    "jszip": "^3.10.1",
    "typescript": "^5.7.2"
  },
  "scripts": {
    "dev": "node esbuild.config.mjs --serve",
    "build": "tsc --noEmit && node esbuild.config.mjs"
  },
  "browserslist": ["> 0.25%, not dead"],
  "resolutions": {
    "terser": ">=5.14.2 ",
    "glob-parent": ">=5.1.2"
  }
}
